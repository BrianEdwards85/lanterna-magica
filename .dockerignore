web/resources/public/js/
web/resources/public/css/app.css
web/resources/public/css/vendor/

# Tests and docs
tests/
*.md
!web/resources/public/**

# Secrets (mounted at runtime)
.secrets.toml

# Beads issue tracking
.beads/

# IDE / OS
.DS_Store
*.swp
.ruff_cache/
.pytest_cache/
